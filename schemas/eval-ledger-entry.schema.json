{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Ledger Entry",
  "type": "object",
  "required": ["version", "timestamp", "commit", "branch", "scores", "results", "status"],
  "properties": {
    "version": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "commit": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pass"],
        "properties": {
          "name": {
            "type": "string"
          },
          "pass": {
            "type": "boolean"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "description": {
      "type": "string"
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "eval-failure.schema.json"
      }
    },
    "dimensionScores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimensionId", "score"],
        "properties": {
          "dimensionId": {
            "type": "string"
          },
          "score": {
            "type": ["number", "null"]
          },
          "method": {
            "type": "string",
            "enum": ["binary", "ratio", "manual"]
          },
          "details": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
