{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://river-review.the3396.com/schemas/pack.schema.json",
  "title": "River Review Skill Pack manifest",
  "description": "Schema for entries under `packs:` in skills/registry.yaml. See docs/development/skill-pack-design.md.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "version", "name", "description", "axis", "tier", "sources", "skills"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "axis": {
        "enum": ["technology", "methodology", "concern"]
      },
      "tier": {
        "enum": ["official", "community", "experimental"]
      },
      "sources": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["name", "reviewed_at"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string" },
            "url": { "type": "string" },
            "reviewed_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          }
        }
      },
      "skills": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      }
    }
  }
}
