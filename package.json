{
  "name": "river-review",
  "version": "1.5.0",
  "private": true,
  "workspaces": [
    "runners/node-api",
    "runners/cli",
    "runners/core"
  ],
  "description": "River Review docs, schemas, and validation utilities.",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/s977043/river-review.git"
  },
  "bin": {
    "river": "./src/cli.mjs",
    "river-review": "./src/cli.mjs"
  },
  "homepage": "https://river-review.the3396.com/",
  "bugs": "https://github.com/s977043/river-review/issues",
  "scripts": {
    "dev": "docusaurus start",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "test": "node --test",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:text": "textlint 'pages/**/*.md'",
    "check:dashes": "node scripts/fix-dashes.mjs --check",
    "lint": "npm run format:check && npm run check:dashes && npm run lint:md && npm run lint:text",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "check:links": "lychee --config .lychee.toml '**/*.md' --exclude-path node_modules --exclude-path '.claude/worktrees/' --exclude-path '(^|/)pages/index\\.md$' --exclude-path '(^|/)pages/index\\.en\\.md$'",
    "check:links:quick": "lychee --config .lychee.toml --max-concurrency 16 '**/*.md' --exclude-path node_modules --exclude-path '.claude/worktrees/' --exclude-path '(^|/)pages/index\\.md$' --exclude-path '(^|/)pages/index\\.en\\.md$'",
    "check:links:local": "lychee --config .lychee.toml --offline '**/*.md' --exclude-path node_modules --exclude-path '.claude/worktrees/' --exclude-path '(^|/)pages/index\\.md$' --exclude-path '(^|/)pages/index\\.en\\.md$'",
    "agents:validate": "node scripts/validate-agents.mjs",
    "skills:validate": "node scripts/validate-skills.mjs",
    "skills:validate:promptfoo": "node scripts/validate-promptfoo-configs.mjs",
    "validate:skill-yaml": "node scripts/validate-skill-yaml.mjs",
    "agent-skills:validate": "node scripts/validate-agent-skills.mjs",
    "skills:catalog": "node scripts/generate-skill-catalog.mjs",
    "create:skill": "node scripts/create-skill.mjs",
    "dashboard:generate": "node scripts/generate-dashboard-data.js",
    "trace:validate": "OTEL_ENABLED=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 node scripts/validate-agents.mjs",
    "fix:dashes": "node scripts/fix-dashes.mjs",
    "planner:eval": "node scripts/evaluate-planner.mjs",
    "planner:eval:dataset": "node scripts/evaluate-planner-dataset.mjs",
    "eval:fixtures": "node scripts/evaluate-review-fixtures.mjs",
    "eval:repo-context": "node scripts/evaluate-repo-wide-fixtures.mjs",
    "meta:validate": "node scripts/validate-meta-consistency.mjs",
    "plugin:validate": "node scripts/validate-plugin-manifest.mjs",
    "eval:all": "node scripts/evaluate-all.mjs",
    "check:bilingual": "node scripts/check-bilingual-pairs.mjs",
    "check:doc-placement": "node scripts/check-doc-placement.mjs",
    "check:docs": "npm run check:bilingual && npm run check:doc-placement",
    "build:action": "ncc build runners/github-action/src/index.mjs -o runners/github-action/dist --source-map --license licenses.txt && node scripts/normalize-dist.mjs",
    "codex:local": "CODEX_HOME=\"$(git rev-parse --show-toplevel)/.codex\" codex -C \"$(git rev-parse --show-toplevel)\"",
    "codex:exec": "CODEX_HOME=\"$(git rev-parse --show-toplevel)/.codex\" codex exec -C \"$(git rev-parse --show-toplevel)\"",
    "river": "node ./src/cli.mjs",
    "prepare": "husky install",
    "eval:regression": "node scripts/evaluate-regression.mjs",
    "eval:compare": "node scripts/compare-eval-ledger.mjs",
    "usage:summary": "node scripts/usage-summary.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^8.5.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.2",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.1.1",
    "openai": "^6.39.0",
    "ora": "^9.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@mermaid-js/layout-elk": "^0.1.9",
    "@vercel/ncc": "^0.38.4",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "prh": "^6.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "textlint": "^15.7.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0"
  }
}
